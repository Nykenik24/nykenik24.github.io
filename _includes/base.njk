<!DOCTYPE html>
<html lang="en">

<head>
	{% if title %}
	<title>{{ title }} - {{ site.title | safe }}</title>
	{% else %}
	<title>{{ site.title | safe }}</title>
	{% endif %}

	<link rel="stylesheet" href="{{ "/assets/css/main.css" | url}}">
  <script src="/assets/js/main.js" defer></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/base16/mocha.min.css">
	<link rel="stylesheet" href="{{ "/assets/css/hjs.css" | url}}">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>

  <script>hljs.highlightAll();</script>
</head>
<body>
	<main>
    <header>
      <a href="/">
        <h1>{{ site.title }}</h1>
      </a>
      {% include "nav.njk" %}
    </header>
		{% block content %}{% endblock %}
    <footer>
      <div class="social">
        {%- for s in site.footerLinks -%}
          <a href="{{ s.href }}" target="_blank">{{ s.name }}</a>
        {%- endfor -%}
      </div>
    </footer>
	</main>
</body>

</html>
