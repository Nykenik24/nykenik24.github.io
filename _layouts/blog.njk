{% extends "base.njk" %}

{% block header %}
<h1>{{ title | safe }}</h1>
{% endblock %}
{% block content %}
  {{ content | safe }}
  <hr>
  <ul class="post-list">
    {% if collections.blog.length > 0 %}
      {%- for post in collections.blog -%}
        {%- if post.data.show -%}
          <li>
            <a href="{{ post.url }}">
              {{ post.data.title }}
              <small>{{ post.data.date }}</small>
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    {% else %}
      <p><strong>Oops! No posts for now.</strong></p>
    {% endif %}
  </ul>
{% endblock %}
